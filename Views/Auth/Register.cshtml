
@model Cartridge.Models.RegisterViewModel
@{


}

<div class="w-100 d-flex flex-column align-items-center row-gap-3 text-std" style="padding-top: 200px;">
    <form method="post" asp-controller="Auth" asp-action="Register">
        @Html.AntiForgeryToken()

        <div class="d-flex flex-column row-gap-2">

            <span asp-validation-summary="All" class="text-danger"></span>

            <input asp-for="Username" 
                   placeholder="Username" 
                   class="nav-search text-std text-primarycstm" />
            <span asp-validation-for="Username" class="text-danger"></span>

            <input asp-for="Email" 
                   placeholder="Email" 
                   type="email"
                   class="nav-search text-std text-primarycstm" />
            <span asp-validation-for="Email" class="text-danger"></span>

            <input asp-for="Password" 
                   placeholder="Password" 
                   type="password" 
                   class="nav-search text-std text-primarycstm" />
            <span asp-validation-for="Password" class="text-danger"></span>

            <button type="submit" class="btn btn-primary bg-default" style="border-color: var(--bs-hover-surface)">Register</button>

            <span>Already have an account? <a href="/auth/login">Login here</a></span>

        </div>
    </form>
</div>